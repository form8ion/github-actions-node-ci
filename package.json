{
  "name": "@form8ion/github-actions-node-ci",
  "description": "CI scaffolder for JavaScript projects on GitHub Actions",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "module",
  "engines": {
    "node": "^18.19.0 || ^20.6.1 || >=22"
  },
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "form8ion/github-actions-node-ci",
  "bugs": "https://github.com/form8ion/github-actions-node-ci/issues",
  "homepage": "https://www.npmjs.com/package/@form8ion/github-actions-node-ci",
  "runkitExampleFilename": "./example.js",
  "exports": "./lib/index.js",
  "main": "./lib/index.js",
  "sideEffects": false,
  "scripts": {
    "pretest": "run-s build",
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "lint:engines": "ls-engines",
    "lint:gherkin": "gplint --config .gplintrc.json",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint",
    "lint:md": "remark . --frail",
    "lint:peer": "npm ls >/dev/null",
    "lint:publish": "publint --strict",
    "lint:sensitive": "ban",
    "test:unit": "run-s 'test:unit:base -- --coverage'",
    "test:unit:base": "NODE_ENV=test DEBUG=any vitest run src/",
    "test:integration": "run-s 'test:integration:base -- --profile noWip'",
    "pretest:integration:base": "run-s build",
    "test:integration:base": "NODE_OPTIONS=--enable-source-maps DEBUG=any cucumber-js test/integration",
    "test:integration:debug": "DEBUG=test run-s test:integration",
    "test:integration:focus": "run-s 'test:integration:base -- --profile focus'",
    "test:integration:wip": "run-s 'test:integration:base -- --profile wip'",
    "test:integration:wip:debug": "DEBUG=test run-s 'test:integration:wip'",
    "prebuild": "run-s clean",
    "build": "npm-run-all --print-label --parallel build:*",
    "build:js": "rollup --config",
    "clean": "rimraf ./lib",
    "pregenerate:md": "npm run build",
    "generate:md": "remark . --output",
    "prepack": "run-s build",
    "prepare": "husky",
    "watch": "run-s 'build:js -- --watch'"
  },
  "files": [
    "example.js",
    "lib/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@12.0.0+sha512.ab3bcf41f35263b968ba233aaefedd2f4862e5eb0118b9f594bc316ddc8be57388b2c5b3a183309fcc6abd68587192faa274e47a7612c6bb4ac6c16b15b505cb",
  "dependencies": {
    "@form8ion/core": "^4.0.0",
    "@form8ion/github-workflows-core": "^5.6.0",
    "@form8ion/javascript-core": "^13.0.0",
    "@vitest/expect": "^3.2.6",
    "semver": "^7.3.7"
  },
  "devDependencies": {
    "@cucumber/cucumber": "11.3.0",
    "@form8ion/commitlint-config": "2.0.19",
    "@form8ion/eslint-config": "7.0.18",
    "@form8ion/eslint-config-cucumber": "1.4.1",
    "@form8ion/eslint-config-vitest": "1.1.0",
    "@form8ion/remark-lint-preset": "6.0.7",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@travi/any": "3.3.0",
    "@vitest/coverage-v8": "3.2.7",
    "ban-sensitive-files": "1.10.11",
    "chai": "6.2.2",
    "cz-conventional-changelog": "3.3.0",
    "gplint": "2.5.2",
    "husky": "9.1.7",
    "lockfile-lint": "5.0.0",
    "lodash.zip": "4.2.0",
    "ls-engines": "0.10.1",
    "mock-fs": "5.5.0",
    "npm-run-all2": "9.0.2",
    "publint": "0.3.21",
    "remark-cli": "12.0.1",
    "remark-toc": "9.0.0",
    "remark-usage": "11.0.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "rollup-plugin-auto-external": "2.0.0",
    "testdouble": "3.20.2",
    "vitest": "3.2.7",
    "vitest-when": "0.10.0"
  }
}
